# Copy this file to .env and fill in your values
# Never share or commit your .env file

# Get this from https://openrouter.ai — it powers the AI recommendations
OPENROUTER_API_KEY=your_openrouter_key_here

# Choose any password you want for the admin panel
ADMIN_PASSWORD=your_admin_password_here

# Port the server runs on (3001 is the default, you usually don't need to change this)
PORT=3001
